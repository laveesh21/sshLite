# =============================================================================
# sshLite environment — copy this file to .env on your HOME PC
# =============================================================================
#   cp .env.example .env
#   nano .env    (set real values; never commit .env)
# =============================================================================

# Port the Node server listens on (use the SAME port in ngrok: ngrok http 3000)
PORT=3000

# Secret used to sign JWTs — use a long random string (32+ characters)
# Generate one: openssl rand -hex 32
JWT_SECRET=use-a-long-random-string-here

# Login credentials for the web UI (only one user in v1)
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password
